%% biblio.bib — bibliography database
%% Add your references here in BibTeX format.
%% ─────────────────────────────────────────────────────────────────────────────

%% Example journal article:
@article{example2024,
  author    = {Last, First and Another, Author},
  title     = {Title of the Article},
  journal   = {Journal Name},
  year      = {2024},
  volume    = {1},
  number    = {1},
  pages     = {1--10},
  doi       = {10.0000/example},
}

%% Example conference paper:
@inproceedings{example2024conf,
  author    = {Last, First},
  title     = {Title of the Paper},
  booktitle = {Proceedings of the Conference Name},
  year      = {2024},
  pages     = {1--10},
  doi       = {10.0000/example},
}

%% Example book:
@book{example2024book,
  author    = {Last, First},
  title     = {Title of the Book},
  publisher = {Publisher Name},
  year      = {2024},
}
